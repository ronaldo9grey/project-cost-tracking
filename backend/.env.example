# 项目成本跟踪系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============================================
# 数据库配置 (必填)
# ============================================
# PostgreSQL 连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://your_username:your_password@your_host:port/your_database

# ============================================
# JWT认证配置 (必填)
# ============================================
# 用于生成JWT令牌的密钥，建议使用随机生成的长字符串
# 可以使用: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production

# ============================================
# 应用配置 (可选)
# ============================================
# 应用名称
APP_NAME=项目管理系统

# 应用版本
APP_VERSION=1.0.0

# 调试模式 (生产环境请设置为 False)
DEBUG=True

# ============================================
# 数据库连接池配置 (可选)
# ============================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================
# JWT配置 (可选)
# ============================================
# 加密算法
ALGORITHM=HS256

# Access Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Refresh Token 过期时间（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS配置 (可选)
# ============================================
# 允许的前端域名，生产环境请设置为具体域名
# 多个域名用逗号分隔: BACKEND_CORS_ORIGINS=["https://app1.com","https://app2.com"]
BACKEND_CORS_ORIGINS=["*"]

# ============================================
# 分页配置 (可选)
# ============================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=1000
