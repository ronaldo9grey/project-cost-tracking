<!--pages/daily-report/daily-report.wxml-->
<view class="container">
  <!-- 日期选择 -->
  <view class="date-selector card">
    <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange">
      <view class="picker-content">
        <text class="label">日报日期</text>
        <text class="value">{{selectedDate}}</text>
        <text class="arrow">></text>
      </view>
    </picker>
  </view>

  <!-- 日报表单 -->
  <view class="report-form">
    <!-- 工作目标 -->
    <view class="form-section card">
      <view class="section-title">
        <text class="required">*</text>
        <text>今日工作目标</text>
      </view>
      <textarea 
        class="form-textarea" 
        placeholder="请描述今天的工作目标..."
        value="{{reportData.work_goals}}"
        bindinput="onInputChange"
        data-field="work_goals"
        maxlength="500"
      />
      <text class="char-count">{{reportData.work_goals.length || 0}}/500</text>
    </view>

    <!-- 关键进展 -->
    <view class="form-section card">
      <view class="section-title">
        <text class="required">*</text>
        <text>关键工作进展</text>
      </view>
      <textarea 
        class="form-textarea" 
        placeholder="请描述关键工作进展和重要成果..."
        value="{{reportData.key_progress}}"
        bindinput="onInputChange"
        data-field="key_progress"
        maxlength="1000"
      />
      <text class="char-count">{{reportData.key_progress.length || 0}}/1000</text>
    </view>

    <!-- 工作事项 -->
    <view class="form-section card">
      <view class="section-header">
        <view class="section-title">
          <text class="required">*</text>
          <text>具体工作事项</text>
        </view>
        <text class="add-btn" bindtap="addWorkItem">+ 添加事项</text>
      </view>
      
      <view class="work-items">
        <view class="work-item" wx:for="{{workItems}}" wx:key="index">
          <view class="item-header">
            <text class="item-index">事项 {{index + 1}}</text>
            <text class="delete-btn" bindtap="deleteWorkItem" data-index="{{index}}">删除</text>
          </view>
          <input 
            class="form-input" 
            placeholder="任务名称"
            value="{{item.name}}"
            bindinput="onWorkItemChange"
            data-index="{{index}}"
            data-field="name"
          />
          <view class="item-row">
            <picker class="status-picker" range="{{statusOptions}}" value="{{item.statusIndex}}" bindchange="onStatusChange" data-index="{{index}}">
              <view class="picker-value">{{item.status}}</view>
            </picker>
            <input 
              class="time-input" 
              type="digit"
              placeholder="工时(小时)"
              value="{{item.planned_hours}}"
              bindinput="onWorkItemChange"
              data-index="{{index}}"
              data-field="planned_hours"
            />
          </view>
        </view>
      </view>
      
      <view wx:if="{{workItems.length === 0}}" class="empty-tip">
        点击"添加事项"添加工作事项
      </view>
    </view>

    <!-- 明日计划 -->
    <view class="form-section card">
      <view class="section-title">
        <text>明日工作计划</text>
      </view>
      <textarea 
        class="form-textarea" 
        placeholder="请描述明天的工作计划..."
        value="{{reportData.tomorrow_plan}}"
        bindinput="onInputChange"
        data-field="tomorrow_plan"
        maxlength="500"
      />
    </view>

    <!-- 自我评价 -->
    <view class="form-section card">
      <view class="section-title">
        <text>自我评价</text>
      </view>
      <view class="evaluation-options">
        <view 
          class="option {{reportData.self_evaluation === item.value ? 'active' : ''}}" 
          wx:for="{{evaluationOptions}}" 
          wx:key="value"
          bindtap="selectEvaluation"
          data-value="{{item.value}}"
        >
          <text class="option-grade">{{item.grade}}</text>
          <text class="option-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-actions">
    <button class="btn btn-primary save-btn" bindtap="saveReport">保存草稿</button>
    <button class="btn btn-success submit-btn" bindtap="submitReport">提交日报</button>
  </view>

  <!-- AI生成弹窗 -->
  <view class="ai-modal" wx:if="{{showAIModal}}">
    <view class="modal-mask" bindtap="closeAIModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text>AI 生成日报</text>
        <text class="close-btn" bindtap="closeAIModal">×</text>
      </view>
      <view class="modal-body">
        <textarea 
          class="ai-input" 
          placeholder="请简要描述今天的工作内容，AI将为您生成完整日报..."
          value="{{aiInput}}"
          bindinput="onAIInputChange"
        />
        <button class="btn btn-primary generate-btn" bindtap="generateByAI">开始生成</button>
      </view>
    </view>
  </view>
</view>
