/**pages/daily-report/daily-report.wxss**/
/* 日期选择器 */
.date-selector .picker-content {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.date-selector .label {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.date-selector .value {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.date-selector .arrow {
  font-size: 28rpx;
  color: #999;
}

/* 表单区域 */
.form-section {
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.section-title .required {
  color: #f5222d;
  margin-right: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #1890ff;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 工作事项 */
.work-items {
  margin-top: 20rpx;
}

.work-item {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-index {
  font-size: 26rpx;
  color: #666;
}

.delete-btn {
  font-size: 24rpx;
  color: #f5222d;
}

.item-row {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.status-picker {
  flex: 1;
}

.picker-value {
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
}

.time-input {
  width: 200rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
}

.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 自我评价 */
.evaluation-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.option {
  flex: 1;
  min-width: 140rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.option.active {
  background: #e6f7ff;
  border-color: #1890ff;
}

.option-grade {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.option.active .option-grade {
  color: #1890ff;
}

.option-label {
  font-size: 24rpx;
  color: #666;
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.save-btn, .submit-btn {
  flex: 1;
}

/* AI弹窗 */
.ai-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
}

.ai-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.generate-btn {
  width: 100%;
}

/* 安全区域 */
.container {
  padding-bottom: 140rpx;
}
