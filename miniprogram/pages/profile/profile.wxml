<!--pages/profile/profile.wxml-->
<view class="container">
  <view class="user-card card">
    <view class="user-info">
      <view class="avatar">
        <text class="avatar-text">{{userInfo.name ? userInfo.name[0] : 'U'}}</text>
      </view>
      <view class="user-detail">
        <text class="user-name">{{userInfo.name || '未登录'}}</text>
        <text class="user-dept">{{userInfo.department}} | {{userInfo.position}}</text>
      </view>
    </view>
  </view>
  
  <view class="menu-list card">
    <view class="menu-item" bindtap="bindWechat">
      <text class="menu-icon">💬</text>
      <text class="menu-text">绑定企业微信</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="notificationSettings">
      <text class="menu-icon">🔔</text>
      <text class="menu-text">通知设置</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
